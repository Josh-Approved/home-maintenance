{
  "expo": {
    "name": "Home Upkeep",
    "slug": "home-maintenance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshapproved.homemaintenance",
      "infoPlist": {
        "CFBundleName": "Home Upkeep",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7B5B44"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.joshapproved.homemaintenance"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "josh-approved",
    "plugins": [
      "./plugins/withGradleJvmArgs",
      "expo-sqlite",
      "expo-sharing",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-font",
      "expo-notifications",
      "expo-mail-composer",
      "expo-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "adeb5a71-8eb1-4da4-80ce-f5c6a599c56d"
      }
    }
  }
}