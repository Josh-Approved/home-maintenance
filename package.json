{
  "name": "home-maintenance",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "expo": "~57.0.4",
    "expo-application": "~57.0.0",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-mail-composer": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-sharing": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "lucide-react-native": "^1.23.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start --port 8366",
    "android": "expo run:android --port 8366",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios --port 8366",
    "web": "expo start --web",
    "test": "jest"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg))"
    ],
    "reporters": [
      "default",
      "<rootDir>/qa/defect-reporter.cjs"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/qa/quarantine.setup.cjs"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/qa/known-bad/"
    ]
  }
}
